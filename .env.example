# === Bot Telegram ===
TELEGRAM_BOT_TOKEN=mettre_ici_le_token
TELEGRAM_CHAT_ID=

# === Base de données ===
DB_PATH=/opt/cyber-news-bot/data/cybernews.sqlite

# === Logs ===
LOG_DIR=/opt/cyber-news-bot/logs
LOG_LEVEL=INFO

# === Collecte ===
CHECK_INTERVAL_MINUTES=30
BACKFILL_DAYS=60
BACKFILL_MODE=silent

# === Alertes Telegram ===
MIN_CVSS_ALERT=7.0
MIN_EPSS_ALERT=0.10
MIN_SCORE_ALERT=35.0
MAX_HIGH_ALERTS_PER_HOUR=5
ALERT_BATCH_WAIT_MINUTES=15

# === Résumés ===
DAILY_SUMMARY_HOUR=08:00
LANG=fr

# === Watchlist — produits/éditeurs prioritaires (séparés par virgule) ===
WATCH_VENDORS=
WATCH_PRODUCTS=
WATCHLIST_SCORE_BOOST=25.0

# === Enrichissement CVE ===
ENRICH_CVE=true
ENRICH_EPSS=true

# === APIs (optionnel) ===
# NVD API Key — https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
# GitHub Token — https://github.com/settings/tokens (scope: public_repo)
GITHUB_TOKEN=

# === Proxy (optionnel) ===
# HTTP_PROXY=http://proxy:3128
# HTTPS_PROXY=http://proxy:3128
