# === Bot Telegram ===
# Token fourni par @BotFather
TELEGRAM_BOT_TOKEN=mettre_ici_le_token

# Chat ID de destination (groupe ou utilisateur)
# Laisser vide au premier démarrage, puis remplir après avoir lancé --get-chat-id
TELEGRAM_CHAT_ID=

# === Base de données ===
DB_PATH=/opt/cyber-news-bot/data/cybernews.sqlite

# === Comportement du bot ===
# Intervalle en minutes entre chaque cycle de récupération
CHECK_INTERVAL_MINUTES=30

# Nombre de jours à récupérer lors du backfill initial
BACKFILL_DAYS=60

# Score CVSS minimum pour déclencher une alerte Telegram
MIN_CVSS_ALERT=7.0

# === Langue des résumés (fr recommandé) ===
LANG=fr

# === Niveau de log (DEBUG, INFO, WARNING, ERROR) ===
LOG_LEVEL=INFO

# === Mode backfill (summary | silent) ===
# summary = envoie un rapport de synthèse initial
# silent  = remplit la BDD sans envoyer d'alertes
BACKFILL_MODE=silent

# === Heure du résumé quotidien (format HH:MM) ===
DAILY_SUMMARY_HOUR=08:00

# === NVD API Key (optionnel, augmente les limites) ===
# Obtenir sur https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# === GitHub Token (optionnel, pour GitHub Security Advisories) ===
# Obtenir sur https://github.com/settings/tokens (scope: public_repo)
GITHUB_TOKEN=

# === Proxy (optionnel) ===
# HTTP_PROXY=http://proxy:3128
# HTTPS_PROXY=http://proxy:3128
